{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Instagram Followback",
  "mainBinaryName": "Instagram Followback",
  "version": "0.4.0",
  "identifier": "com.mishabelyakov.instagramfollowback",
  "build": {
    "frontendDist": "../desktop-shell",
    "beforeBuildCommand": "npm run desktop:prepare-runtime"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "publisher": "Misha Belyakov",
    "copyright": "Copyright (c) 2026 Misha Belyakov",
    "shortDescription": "Local desktop app for checking Instagram followback relationships.",
    "longDescription": "Instagram Followback is a local-first desktop app that checks non-followers, fans, and mutuals using a private Instagram session and a bundled Python live engine.",
    "macOS": {
      "bundleName": "Instagram Followback",
      "minimumSystemVersion": "13.0"
    },
    "resources": {
      "../instagram_followback_checker.py": "python/instagram_followback_checker.py",
      "../instagram_followback_live.py": "python/instagram_followback_live.py",
      "../instagram_followback_desktop_bridge.py": "python/instagram_followback_desktop_bridge.py",
      "../instagram_nonfollowers.py": "python/instagram_nonfollowers.py",
      "../.desktop-runtime/python": "python-runtime/python",
      "../.desktop-runtime/playwright-browsers": "python-runtime/playwright-browsers"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Instagram Followback",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "center": true
      }
    ]
  }
}
